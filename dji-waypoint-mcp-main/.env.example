# DJI Waypoint MCP Service Configuration

# Logging
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# MCP Server
MCP_SERVER_NAME=dji-waypoint-mcp
MCP_SERVER_VERSION=0.1.0

# File Paths
TEMP_DIR=/tmp/dji-waypoint-mcp
OUTPUT_DIR=./output

# Coordinate Systems
DEFAULT_COORD_SYS=WGS84
DEFAULT_HEIGHT_MODE=EGM96

# Safety Limits
MAX_WAYPOINTS=1000
MAX_FLIGHT_DISTANCE=50000  # meters
MAX_FLIGHT_HEIGHT=500      # meters